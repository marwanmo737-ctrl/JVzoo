# ===== General =====
NODE_ENV=production
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# ===== Database =====
# في الإنتاج، هذا يجب أن يشير إلى مسار على قرص دائم (persistent disk/volume)
# وإلا ستُمحى قاعدة البيانات مع كل إعادة نشر. راجع README لتعليمات كل منصة.
DB_PATH=./data.sqlite

# ===== Groq =====
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ===== Auth =====
JWT_SECRET=change_this_to_a_very_long_random_secret_string
JWT_EXPIRES_IN=30d
COOKIE_SECURE=false

# ===== JVzoo =====
JVZOO_SECRET_KEY=your_jvzoo_secret_key_from_dashboard
JVZOO_PRODUCT_ID_STARTER=100001
JVZOO_PRODUCT_ID_PRO=100002
JVZOO_PRODUCT_ID_AGENCY=100003

# ===== Resend Email =====
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=LandingAI <onboarding@yourdomain.com>
SUPPORT_EMAIL=support@yourdomain.com
